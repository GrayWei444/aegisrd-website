---
// 首頁 — 公司形象官網（2026-07-16 用戶定調）：banner + 簡介 + 產品入口(薄) + 聯絡留言。
// 產品細節一律落在各自產品頁，首頁不展開。
import Base from '../layouts/Base.astro';
---
<Base
  title="AegisRD 安心研創 — 端對端加密通訊與傳輸技術公司"
  description="AegisRD 安心研創：端對端加密技術公司。旗艦產品 AegisTalk 安心說（AI 防詐加密通訊）與 AegisTrans 安心傳（跨裝置加密傳輸）。"
  altPath="/en"
  active="home"
>
  <!-- Banner — 公司門面（文字置中） -->
  <section class="hero" style="min-height:72vh">
    <div class="hero-content">
      <div class="hero-badge"><img src="/img/shield.png" alt="" style="height:1.2em;vertical-align:-.25em;margin-right:.15em" /> AegisRD 安心研創</div>
      <h1 style="font-size:clamp(2.4rem,5vw,4rem)">端對端加密<br />通訊與傳輸<span class="gradient">技術公司</span></h1>
      <p>「安心」不靠政策承諾，由架構保證 —— 加密在裝置端、AI 在本地、內容 100% 點對點。</p>
      <div class="hero-actions">
        <a href="/aegistalk" class="btn-primary"><img src="/img/aegistalk-logo.png" alt="" style="height:1.35em;vertical-align:-.3em;margin-right:.2em" />AegisTalk 安心說</a>
        <a href="/aegistrans" class="btn-primary" style="background:linear-gradient(135deg,var(--blue),#60a5fa);box-shadow:0 4px 20px rgba(59,130,246,0.3)"><img src="/img/aegistrans-logo.png" alt="" style="height:1.35em;vertical-align:-.3em;margin-right:.2em" />AegisTrans 安心傳</a>
        <a href="/安心追" class="btn-primary" style="background:linear-gradient(135deg,var(--green),#16a34a);box-shadow:0 4px 20px rgba(34,197,94,0.3)"><img src="/img/shield.png" alt="" style="height:1.35em;vertical-align:-.3em;margin-right:.2em" />安心追 查詐騙</a>
        <a href="#contact" class="btn-ghost">聯絡我們</a>
      </div>
    </div>
  </section>

  <!-- 技術帶 strip -->
  <section style="padding:1.4rem 2rem;background:var(--bg2);border-top:1px solid var(--border);border-bottom:1px solid var(--border)">
    <div class="container" style="display:flex;gap:2.5rem;flex-wrap:wrap;justify-content:center;align-items:center">
      <span style="color:var(--text2);font-size:.9rem"><svg width="1em" height="1em" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="vertical-align:-.15em;margin-right:.25em"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg>Signal Protocol 端對端加密</span>
      <span style="color:var(--text2);font-size:.9rem"><svg width="1em" height="1em" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="vertical-align:-.15em;margin-right:.25em"><circle cx="18" cy="5" r="3"></circle><circle cx="6" cy="12" r="3"></circle><circle cx="18" cy="19" r="3"></circle><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"></line><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"></line></svg>100% P2P · 伺服器零內容</span>
      <span style="color:var(--text2);font-size:.9rem"><svg width="1em" height="1em" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="vertical-align:-.15em;margin-right:.25em"><path d="M12 8V4H8"></path><rect width="16" height="12" x="4" y="8" rx="2"></rect><path d="M2 14h2"></path><path d="M20 14h2"></path><path d="M15 13v2"></path><path d="M9 13v2"></path></svg>本地 Edge AI（Rust + WASM）</span>
      <a href="#technology" style="color:var(--accent);font-size:.9rem">核心技術 ↓</a>
    </div>
  </section>

  <!-- 關於 -->
  <section class="problem" style="padding:5rem 2rem">
    <div class="container">
      <div class="section-label">// ABOUT</div>
      <h2 class="section-title reveal">關於安心研創</h2>
      <p class="section-desc reveal" style="max-width:820px">
        AegisRD 安心研創是一家端對端加密技術公司。我們把同一副安全骨架交付到兩個日常場景：
        對「別人」的通訊要防詐，對「自己」的傳輸要私密。
      </p>
      <p style="margin-top:1.5rem"><a href="/about" class="btn-ghost">團隊與沿革 →</a></p>
    </div>
  </section>

  <!-- 產品入口（薄卡 — 細節在產品頁） -->
  <section class="ecosystem" id="products">
    <div class="container">
      <div class="section-label">// PRODUCTS</div>
      <h2 class="section-title reveal">產品與服務</h2>
      <div class="eco-grid" style="margin-top:3rem">
        <a href="/aegistalk" class="eco-card talk reveal" style="text-decoration:none;color:inherit;display:block">
          <div class="eco-step">防詐加密通訊</div>
          <h3>AegisTalk 安心說</h3>
          <div class="tagline">在加密通話內即時用 AI 攔截詐騙</div>
          <p style="color:var(--accent);margin-top:1rem">了解更多 →</p>
        </a>
        <a href="/aegistrans" class="eco-card vpn reveal" style="text-decoration:none;color:inherit;display:block">
          <div class="eco-step">跨裝置加密傳輸</div>
          <h3>AegisTrans 安心傳</h3>
          <div class="tagline">你的檔案，只走你的裝置</div>
          <p style="color:var(--accent);margin-top:1rem">了解更多 →</p>
        </a>
        <a href="/aegistalk/pay" class="eco-card pay reveal" style="text-decoration:none;color:inherit;display:block">
          <div class="eco-step">支付風控模組 · 核心已完成鏈上實測</div>
          <h3>AegisPay 安心付</h3>
          <div class="tagline">付款前的最後一道閘門 — 非託管風控</div>
          <p style="color:var(--accent);margin-top:1rem">了解更多 →</p>
        </a>
        <a href="/#technology" class="eco-card track reveal" style="text-decoration:none;color:inherit;display:block">
          <div class="eco-step">技術底座</div>
          <h3>AegisAI × AegisID</h3>
          <div class="tagline">三層防詐引擎 × 裝置無關生物身份</div>
          <p style="color:var(--accent);margin-top:1rem">核心技術 ↓</p>
        </a>
      </div>
    </div>
  </section>

  <!-- 核心技術（原 /technology 分頁併入首頁） -->
  <section class="ai-engine" id="technology">
    <div class="container">
      <div class="section-label">// TECHNOLOGY</div>
      <h2 class="section-title reveal">核心技術 — 兩個產品，同一副骨架</h2>
      <p class="section-desc reveal">隱私是架構保證，不是政策承諾。</p>
      <div class="ai-layers" style="max-width:860px">
        <div class="ai-layer reveal">
          <div class="layer-badge l1"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg></div>
          <div class="layer-info">
            <h4>端對端加密 — Signal Protocol</h4>
            <p>X3DH 金鑰協商 + Double Ratchet 前向保密。訊息與檔案離開裝置前就已加密 —— 我們想看也看不到。</p>
          </div>
        </div>
        <div class="ai-layer reveal">
          <div class="layer-badge l2"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="18" cy="5" r="3"></circle><circle cx="6" cy="12" r="3"></circle><circle cx="18" cy="19" r="3"></circle><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"></line><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"></line></svg></div>
          <div class="layer-info">
            <h4>100% P2P — 伺服器零內容</h4>
            <p>內容走 WebRTC DataChannel 點對點直達，伺服器只做信令 —— 零中繼、零留存、零可外洩。</p>
          </div>
        </div>
        <div class="ai-layer reveal">
          <div class="layer-badge l3"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 8V4H8"></path><rect width="16" height="12" x="4" y="8" rx="2"></rect><path d="M2 14h2"></path><path d="M20 14h2"></path><path d="M15 13v2"></path><path d="M9 13v2"></path></svg></div>
          <div class="layer-info">
            <h4>本地 Edge AI — Rust + WASM</h4>
            <p>三層防詐引擎（黑白名單 / 53,640 條規則 × fastText 語意融合 / 行為基線）全部跑在裝置上 —— 98.5% 偵測率、F1 0.981（26,137 則實測，域內測試）。</p>
          </div>
        </div>
        <div class="ai-layer reveal">
          <div class="layer-badge l1"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 7V5a2 2 0 0 1 2-2h2"></path><path d="M17 3h2a2 2 0 0 1 2 2v2"></path><path d="M21 17v2a2 2 0 0 1-2 2h-2"></path><path d="M7 21H5a2 2 0 0 1-2-2v-2"></path><path d="M9 9h.01"></path><path d="M15 9h.01"></path><path d="M9.5 14a3.5 3.5 0 0 0 5 0"></path></svg></div>
          <div class="layer-info">
            <h4>AegisID 生物身份 — 僅存向量，不存照片</h4>
            <p>AuraFace 512 維臉部特徵向量 + 活體防偽。換手機不掉帳號；受控測試 FRR 0%、LFW 843 萬組比對驗證。</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 聯絡 / 留言 -->
  <section class="cost" id="contact" style="padding:6rem 2rem">
    <div class="container" style="max-width:720px">
      <div class="section-label">// CONTACT</div>
      <h2 class="section-title reveal">聯絡我們</h2>
      <p class="section-desc reveal">產品合作、媒體採訪、Beta 測試邀請 —— 留言給我們，或直接來信 <a href="mailto:contact@aegisrd.com" style="color:var(--accent)">contact@aegisrd.com</a>。</p>
      <form id="contact-form" style="margin-top:2.5rem;display:flex;flex-direction:column;gap:1rem">
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem">
          <input name="name" required maxlength="80" placeholder="您的稱呼"
            style="background:var(--bg);border:1px solid var(--border);border-radius:10px;padding:.9rem 1rem;color:var(--text);font-size:.95rem" />
          <input name="email" type="email" required maxlength="160" placeholder="您的 Email"
            style="background:var(--bg);border:1px solid var(--border);border-radius:10px;padding:.9rem 1rem;color:var(--text);font-size:.95rem" />
        </div>
        <select name="subject" required
          style="background:var(--bg);border:1px solid var(--border);border-radius:10px;padding:.9rem 1rem;color:var(--text);font-size:.95rem">
          <option value="">主旨 — 請選擇</option>
          <option value="合作洽談">合作洽談</option>
          <option value="媒體採訪">媒體採訪</option>
          <option value="Beta 測試">Beta 測試邀請</option>
          <option value="其他">其他</option>
        </select>
        <textarea name="message" required maxlength="2000" rows="5" placeholder="想說的話…"
          style="background:var(--bg);border:1px solid var(--border);border-radius:10px;padding:.9rem 1rem;color:var(--text);font-size:.95rem;resize:vertical"></textarea>
        <button type="submit" class="btn-primary" style="border:none;cursor:pointer;font-family:inherit">送出留言</button>
        <p id="contact-status" style="font-size:.9rem;color:var(--text2)"></p>
      </form>
    </div>
  </section>

  <script>
    // 留言 → 同源 /api/contact（Caddy 反代至 AegisRD API，零第三方）
    const form = document.getElementById('contact-form') as HTMLFormElement;
    const status = document.getElementById('contact-status')!;
    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const btn = form.querySelector('button')!;
      btn.setAttribute('disabled', '');
      status.textContent = '送出中…';
      try {
        const data = Object.fromEntries(new FormData(form).entries());
        const r = await fetch('/api/contact', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data),
        });
        if (!r.ok) throw new Error(String(r.status));
        form.reset();
        status.textContent = '✅ 已收到您的留言，我們會盡快回覆。';
      } catch {
        status.textContent = '送出失敗 — 請直接來信 contact@aegisrd.com';
      } finally {
        btn.removeAttribute('disabled');
      }
    });
  </script>

<style>
  @media (max-width: 860px) {
    .hero .container { grid-template-columns: 1fr !important; }
    .hero { text-align: center !important; }
    .hero .hero-actions { justify-content: center !important; }
    .hero [aria-hidden="true"] { display: none; }
    #contact-form > div { grid-template-columns: 1fr !important; }
  }
</style>
</Base>
