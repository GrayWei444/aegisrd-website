---
// AegisTrans 產品頁 — 規格 v1.2 §3.4。語源：AegisTrans/README.md（程式碼實況 2026-07-16）。
import Base from '../layouts/Base.astro';
---
<Base
  title="AegisTrans 安心傳 — 你的裝置，一起工作"
  description="AegisTrans 是跨裝置傳給自己的加密工作區。各種檔案不壓縮，訊息與檔案內容以端對端加密 P2P 直傳，支援 iOS、Android、macOS、Windows 與 Linux。"
  active="aegistrans"
>
  <!-- Hero -->
  <section class="hero" style="min-height:80vh">
    <div class="hero-content">
      <div class="hero-badge">📡 AegisTrans 安心傳 · Beta</div>
      <h1>你的裝置，<span class="gradient">一起工作</span></h1>
      <p>
        iPhone、Android、Mac、Windows、Linux，跨裝置傳給自己。
        訊息與檔案內容端對端加密、裝置間 P2P 直傳，不上傳到 AegisRD 伺服器。
      </p>
      <div class="hero-actions">
        <a href="#download" class="btn-primary">直接下載桌面版 ↓</a>
        <a href="https://trans.aegisrd.com" class="btn-ghost">免安裝試用 Web 版 ↗</a>
        <a href="#promises" class="btn-ghost">五個核心訴求 ↓</a>
      </div>
    </div>
  </section>

  <!-- 核心產品訴求 -->
  <section class="problem" id="promises">
    <div class="container">
      <div class="section-label">// FIVE PROMISES</div>
      <h2 class="section-title reveal">跨裝置工作，不必先把內容交給雲端</h2>
      <p class="section-desc reveal">從傳一張照片，到把另一台電腦變成第二螢幕，AegisTrans 圍繞五件事打造。</p>
      <div class="problem-stat promise-grid">
        <div class="stat-card reveal">
          <div class="number" style="font-size:2rem">📄 各種檔案</div>
          <div class="desc">照片、影片、文件、壓縮檔或程式碼都能傳；AegisTrans 不改格式、不壓縮內容。</div>
        </div>
        <div class="stat-card reveal">
          <div class="number" style="font-size:2rem">📱 五個平台</div>
          <div class="desc">iOS、Android、macOS、Windows、Linux，同一個帳號登入即可找到自己的裝置。</div>
        </div>
        <div class="stat-card reveal">
          <div class="number" style="font-size:2rem">🔒 內容不過站</div>
          <div class="desc">訊息與檔案先加密，再透過 WebRTC 在裝置間直傳；AegisRD 伺服器不接收內容。</div>
        </div>
        <div class="stat-card reveal">
          <div class="number" style="font-size:2rem">💾 留在裝置</div>
          <div class="desc">原生 App 儲存的檔案不設到期日。Pro 原生版即將支援無限單檔大小，只受裝置可用空間限制。</div>
        </div>
        <div class="stat-card reveal">
          <div class="number" style="font-size:2rem">🖥️ 畫面接力</div>
          <div class="desc">在裝置間投放螢幕；桌面版可把另一台電腦作為延伸畫面。各平台能力依 Beta 進度開放。</div>
        </div>
      </div>
      <p class="scope-note reveal">
        目前 Beta 全平台單檔上限為 2GB。「無限單檔」正在完成中，推出時僅適用於 Pro 原生 App；Web 版仍受瀏覽器限制。
      </p>
    </div>
  </section>

  <!-- Free / Pro 方案 -->
  <section class="cost" id="plans">
    <div class="container">
      <div class="section-label">// FREE OR PRO</div>
      <h2 class="section-title reveal">先免費使用，需要更多再升級</h2>
      <p class="section-desc reveal">核心加密與 P2P 不分方案。Pro 解鎖的是更多裝置、更大的本機工作空間，以及主動螢幕投放與延伸。</p>
      <div class="moat-compare plan-grid">
        <div class="moat-col reveal">
          <div class="plan-name">Free</div>
          <div class="plan-price">NT$0</div>
          <ul>
            <li><span class="check">✓</span> 2 台裝置</li>
            <li><span class="check">✓</span> 各種檔案類型、原始內容不壓縮</li>
            <li><span class="check">✓</span> 端對端加密 P2P 傳輸</li>
            <li><span class="check">✓</span> 正式版單檔最高 1GB、總儲存 2GB</li>
            <li><span class="check">✓</span> 免費接收螢幕投放</li>
            <li><span class="check">✓</span> Web 版免安裝入口</li>
          </ul>
        </div>
        <div class="moat-col highlight reveal">
          <div class="plan-name">Pro</div>
          <div class="plan-price">NT$30 <small>/ 月</small></div>
          <div class="plan-alt">NT$300 / 年 · NT$900 終身</div>
          <ul>
            <li><span class="check">✓</span> 最多 10 台裝置</li>
            <li><span class="check">✓</span> 包含 Free 的全部核心功能</li>
            <li><span class="check">✓</span> 原生 App 無限單檔大小 <b>即將推出</b></li>
            <li><span class="check">✓</span> 總儲存量只受裝置可用空間限制</li>
            <li><span class="check">✓</span> 主動投放螢幕與桌面延伸</li>
            <li><span class="check">✓</span> 同一帳號跨平台套用 Pro 權益</li>
          </ul>
        </div>
      </div>
      <p class="scope-note reveal">
        「無限」指原生 App 不設定單檔大小上限，實際仍受裝置剩餘空間、作業系統與檔案系統限制。PWA 即使帳號已有 Pro，也不解除瀏覽器的檔案大小與儲存限制。正式價格以 App Store／Google Play 顯示為準。
      </p>
    </div>
  </section>

  <!-- 技術特點 -->
  <section class="ai-engine">
    <div class="container">
      <div class="section-label">// TECHNOLOGY</div>
      <h2 class="section-title reveal">與 AegisTalk 同一副骨架</h2>
      <p class="section-desc reveal">AegisTrans 與 AegisTalk 共用底層技術 —— 差別只在場景：一個對別人，一個對自己。</p>
      <div class="ai-layers">
        <div class="ai-layer reveal">
          <div class="layer-badge l1">P2P</div>
          <div class="layer-info">
            <h4>WebRTC DataChannel 直達</h4>
            <p>兩台裝置透過點對點連線傳遞內容；分塊傳輸與流量控制讓大檔傳輸維持穩定，不經 AegisRD 中繼內容。</p>
          </div>
        </div>
        <div class="ai-layer reveal">
          <div class="layer-badge l2">E2E</div>
          <div class="layer-info">
            <h4>公開、成熟的密碼學設計</h4>
            <p>以 X3DH、Double Ratchet 與 AES-256-GCM 建立裝置間信任並加密內容；傳輸線上只看得到密文。</p>
          </div>
        </div>
        <div class="ai-layer reveal">
          <div class="layer-badge l3">0️⃣</div>
          <div class="layer-info">
            <h4>伺服器不接收內容</h4>
            <p>服務端只處理帳號、裝置狀態與建立 P2P 連線所需的信令；訊息與檔案內容不經服務端。</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 與 AegisTalk 的關係 -->
  <section class="moat">
    <div class="container">
      <div class="section-label">// ECOSYSTEM</div>
      <h2 class="section-title reveal">同一個生態系的兩張面孔</h2>
      <div class="moat-compare">
        <div class="moat-col reveal">
          <h4>💬 AegisTalk 安心說</h4>
          <ul>
            <li>對「別人」的加密通訊</li>
            <li>AI 防詐引擎全程護航</li>
            <li>家庭守護、風險警示</li>
          </ul>
        </div>
        <div class="moat-col highlight reveal">
          <h4>📡 AegisTrans 安心傳</h4>
          <ul>
            <li>對「自己」的跨裝置同步</li>
            <li>各種檔案原始內容直傳</li>
            <li>螢幕投放 / 桌面延伸</li>
          </ul>
        </div>
      </div>
      <p class="section-desc reveal" style="margin-top:2rem">
        兩者共用 AegisRD 同一套 E2EE + P2P 底座 —— 學會一個，就等於學會另一個。
      </p>
    </div>
  </section>

  <!-- 實機展示（一列三張：登入 → 配對 → 訊息流；截圖已打碼） -->
  <section class="screenshots">
    <div class="container">
      <div class="section-label">// SCREENSHOTS</div>
      <h2 class="section-title reveal">產品實機展示</h2>
      <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:1.25rem;margin-top:3rem" class="trans-shots">
        <div class="ss-item" style="width:auto"><img src="/images/trans-login.png" alt="登入" loading="lazy" /><div class="ss-label">① Email + 密碼登入 — 工作階段密碼鎖</div></div>
        <div class="ss-item" style="width:auto"><img src="/images/trans-welcome.png" alt="同帳號多裝置配對" loading="lazy" /><div class="ss-label">② 同帳號登入即自動配對 — Mac / Windows / iPhone</div></div>
        <div class="ss-item" style="width:auto"><img src="/images/trans-message-stream.png" alt="訊息檔案流" loading="lazy" /><div class="ss-label">③ 手機拍的，秒進電腦 — 跨裝置訊息檔案流</div></div>
      </div>
    </div>
  </section>

  <!-- 螢幕投放與延伸（獨立卡片介紹 + 實機圖） -->
  <section class="moat">
    <div class="container">
      <div class="section-label">// SCREEN CAST · <span style="color:var(--warn)">進階功能（正式版採訂閱制）</span></div>
      <h2 class="section-title reveal">螢幕投放與延伸</h2>
      <p class="section-desc reveal">
        <b>投放（鏡像）— 跨裝置</b>：手機或電腦的畫面即時投到另一台裝置（iOS 投放已實機驗證）。<br />
        <b>延伸螢幕 — 桌面版獨家</b>：把另一台電腦變成你的第二螢幕（虛擬顯示器驅動）。<br />
        兩者都走端對端加密 P2P 通道，畫面內容不經伺服器；收端一鍵接受、隨時關閉。
      </p>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:1.25rem;margin-top:2.5rem" class="trans-shots">
        <div class="ss-item" style="width:auto"><img src="/images/trans-screenshare-request.png" alt="收到螢幕分享請求" loading="lazy" /><div class="ss-label">收到分享請求 — 拒絕 / 一鍵接受</div></div>
        <div class="ss-item" style="width:auto"><img src="/images/trans-screencast-fullscreen.png" alt="Mac 即時接收 Windows 畫面" loading="lazy" /><div class="ss-label">Mac 即時接收 Windows PC 畫面（可全螢幕）</div></div>
      </div>
    </div>
  </section>

  <!-- 平台與狀態（照程式碼實況，規格 §3.4「照實標示」） -->
  <section class="cost">
    <div class="container">
      <div class="section-label">// AVAILABILITY</div>
      <h2 class="section-title reveal">平台進度</h2>
      <div class="problem-stat">
        <div class="stat-card reveal"><div class="number" style="font-size:2rem">🌐 Web</div><div class="desc">免安裝試用入口 — 立即開啟，適合先體驗核心傳輸</div></div>
        <div class="stat-card reveal"><div class="number" style="font-size:2rem">🖥️ Mac</div><div class="desc">Beta 可下載 — 含螢幕投放/延伸（已簽章公證）</div></div>
        <div class="stat-card reveal"><div class="number" style="font-size:2rem">🪟 Windows</div><div class="desc">Beta 可下載</div></div>
        <div class="stat-card reveal"><div class="number" style="font-size:2rem">📱 iOS</div><div class="desc">實機測試中</div></div>
        <div class="stat-card reveal"><div class="number" style="font-size:2rem">🐧 Linux</div><div class="desc">Beta 可下載（AppImage）</div></div>
        <div class="stat-card reveal"><div class="number" style="font-size:2rem">🤖 Android</div><div class="desc">App 已完成建置，實機測試中</div></div>
      </div>
    </div>
  </section>

  <!-- 下載（桌面版 Beta 直接下載） -->
  <section class="cta-section" id="download">
    <h2>先試用，再帶到每一台裝置</h2>
    <p>
      Web 版免安裝；Mac 版已簽章公證，Windows / Linux 為 Beta 安裝檔（未簽章，安裝時系統可能提示）。iOS / Android 將於應用商店上架。<br />
      進階功能（螢幕投放／延伸）正式版採<b>訂閱制</b>；於手機 App 內訂閱後，權益隨同一帳號套用到其他裝置。
    </p>
    <div class="hero-actions" style="justify-content:center;margin-bottom:1rem">
      <a href="https://trans.aegisrd.com" class="btn-primary">🌐 免安裝試用 Web 版</a>
    </div>
    <div class="hero-actions" style="justify-content:center">
      <a href="/downloads/AegisTrans-mac.zip" class="btn-primary">🍎 下載 Mac 版（.zip）</a>
      <a href="/downloads/AegisTrans-win-setup.exe" class="btn-primary" style="background:linear-gradient(135deg,var(--blue),#60a5fa)">🪟 下載 Windows 版（.exe）</a>
      <a href="/downloads/AegisTrans-linux.AppImage" class="btn-primary" style="background:linear-gradient(135deg,#7c3aed,#a78bfa)">🐧 下載 Linux 版（AppImage）</a>
    </div>
    <div class="hero-actions" style="justify-content:center;margin-top:1rem">
      <span class="btn-ghost" style="cursor:default">🍎 App Store · 即將上架</span>
      <span class="btn-ghost" style="cursor:default">🤖 Google Play · 即將上架</span>
    </div>
    <p style="margin-top:1.5rem;color:var(--text2);font-size:.9rem">
      問題回報／搶先功能建議：<a href="mailto:contact@aegisrd.com?subject=AegisTrans%20Beta" style="color:var(--accent)">contact@aegisrd.com</a>
    </p>
  </section>
<style>
  .promise-grid { grid-template-columns:repeat(auto-fit,minmax(190px,1fr)); }
  .scope-note {
    max-width:900px;
    margin-top:1.5rem;
    padding:1rem 1.25rem;
    border:1px solid rgba(38,198,218,.2);
    border-radius:12px;
    background:rgba(38,198,218,.06);
    color:var(--text2);
    font-size:.9rem;
  }
  .plan-grid { max-width:900px; }
  .plan-name { color:var(--accent);font-weight:800;letter-spacing:.08em;text-transform:uppercase; }
  .plan-price { font-size:2.4rem;font-weight:900;line-height:1.2;margin:.5rem 0 1rem; }
  .plan-price small { color:var(--text2);font-size:1rem;font-weight:600; }
  .plan-alt { color:var(--text2);font-size:.9rem;margin:-.6rem 0 1rem; }
  @media (max-width: 900px) {
    .trans-shots { grid-template-columns: 1fr !important; }
  }
</style>
</Base>
